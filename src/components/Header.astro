---
import HeaderLink from "./HeaderLink.astro";
import SocialLinks from "./SocialLinks.astro";
---

<header class="sticky top-0 z-10 border-b border-white/10 bg-[#0f1117]/70 backdrop-blur-lg">
	<nav class="mx-auto flex min-h-16 w-[1120px] max-w-[calc(100%-2rem)] items-center justify-between gap-4 max-md:flex-col max-md:items-start max-md:py-4" aria-label="Primary navigation">
		<a class="font-mono text-sm font-bold tracking-[0.08em] text-[#f4efe7] lowercase no-underline before:text-[#facc15] before:content-['~/']" href="/">david</a>
		<div class="flex flex-wrap items-center gap-4 font-mono text-[0.82rem] tracking-[0.04em] text-[#f4efe7] lowercase">
			<HeaderLink href="/blog">01 Blog</HeaderLink>
			<HeaderLink href="/cv">02 CV</HeaderLink>
			<HeaderLink href="/about">03 About</HeaderLink>
		</div>
		<div class="max-md:hidden">
			<SocialLinks />
		</div>
	</nav>
</header>
