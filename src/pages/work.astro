---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Work | David" description="Selected work and projects." wide>
	<section class="py-12">
		<p class="mb-4 font-mono text-xs font-bold tracking-[0.14em] text-[#8ff0a4] uppercase">Work</p>
		<h1 class="m-0 max-w-[16ch] text-[clamp(2.75rem,7vw,5.75rem)] leading-[1.02] font-bold tracking-[-0.055em]">Selected work</h1>
		<p class="mt-6 max-w-2xl text-[clamp(1.15rem,3vw,1.45rem)] text-[#a7adba]">Projects, case studies, open-source work, talks, and other things worth showcasing.</p>
	</section>

	<section class="grid gap-4 md:grid-cols-2">
		<article class="rounded-[18px] border border-white/15 bg-[#161922]/75 p-6">
			<p class="mb-4 font-mono text-xs font-bold tracking-[0.14em] text-[#8ff0a4] uppercase">Project</p>
			<h2 class="m-0 mb-3 text-[clamp(1.6rem,4vw,2.45rem)] leading-[1.02] font-bold tracking-[-0.055em]">Project name</h2>
			<p class="text-[#a7adba]">Short summary of what you made, why it mattered, and what your role was.</p>
			<a class="text-[#d7c3ff] hover:text-[#8ff0a4]" href="#">Add details →</a>
		</article>
		<article class="rounded-[18px] border border-white/15 bg-[#161922]/75 p-6">
			<p class="mb-4 font-mono text-xs font-bold tracking-[0.14em] text-[#8ff0a4] uppercase">Writing / Talk</p>
			<h2 class="m-0 mb-3 text-[clamp(1.6rem,4vw,2.45rem)] leading-[1.02] font-bold tracking-[-0.055em]">Notable thing</h2>
			<p class="text-[#a7adba]">Use these cards for public artifacts that represent your thinking and taste.</p>
			<a class="text-[#d7c3ff] hover:text-[#8ff0a4]" href="#">Add link →</a>
		</article>
	</section>
</BaseLayout>
