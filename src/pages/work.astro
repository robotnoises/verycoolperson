---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Work | Very Cool Person" description="Selected work and projects." wide>
	<section class="page-header">
		<p class="eyebrow">Work</p>
		<h1>Selected work</h1>
		<p class="lede">Projects, case studies, open-source work, talks, and other things worth showcasing.</p>
	</section>

	<section class="grid two-up">
		<article class="card">
			<p class="eyebrow">Project</p>
			<h2>Project name</h2>
			<p>Short summary of what you made, why it mattered, and what your role was.</p>
			<a href="#">Add details →</a>
		</article>
		<article class="card">
			<p class="eyebrow">Writing / Talk</p>
			<h2>Notable thing</h2>
			<p>Use these cards for public artifacts that represent your thinking and taste.</p>
			<a href="#">Add link →</a>
		</article>
	</section>
</BaseLayout>
