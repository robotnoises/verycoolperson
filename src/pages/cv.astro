---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV | David" description="CV and professional background.">
	<section class="py-12">
		<p class="mb-4 font-mono text-xs font-bold tracking-[0.14em] text-[#8ff0a4] uppercase">CV</p>
		<h1 class="m-0 max-w-[16ch] text-[clamp(2.75rem,7vw,5.75rem)] leading-[1.02] font-bold tracking-[-0.055em]">Curriculum vitae</h1>
		<p class="mt-6 max-w-2xl text-[clamp(1.15rem,3vw,1.45rem)] text-[#a7adba]">Professional history, skills, and selected accomplishments.</p>
	</section>

	<section class="grid gap-8">
		<article class="border-l-4 border-white/15 pl-4">
			<p class="font-mono text-sm text-[#a7adba]">YYYY–Present</p>
			<h2 class="m-0 mb-3 text-[clamp(1.6rem,4vw,2.45rem)] leading-[1.02] font-bold tracking-[-0.055em]">Role, Organization</h2>
			<p>Brief description of your responsibilities, scope, and impact.</p>
		</article>
		<article class="border-l-4 border-white/15 pl-4">
			<p class="font-mono text-sm text-[#a7adba]">YYYY–YYYY</p>
			<h2 class="m-0 mb-3 text-[clamp(1.6rem,4vw,2.45rem)] leading-[1.02] font-bold tracking-[-0.055em]">Earlier role, Organization</h2>
			<p>Another concise entry.</p>
		</article>
	</section>
</BaseLayout>
