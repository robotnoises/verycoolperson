---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV | Very Cool Person" description="CV and professional background.">
	<section class="page-header">
		<p class="eyebrow">CV</p>
		<h1>Curriculum vitae</h1>
		<p class="lede">Professional history, skills, and selected accomplishments.</p>
	</section>

	<section class="timeline">
		<article>
			<p class="date-range">YYYY–Present</p>
			<h2>Role, Organization</h2>
			<p>Brief description of your responsibilities, scope, and impact.</p>
		</article>
		<article>
			<p class="date-range">YYYY–YYYY</p>
			<h2>Earlier role, Organization</h2>
			<p>Another concise entry.</p>
		</article>
	</section>
</BaseLayout>
