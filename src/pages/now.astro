---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Now | David" description="What I am focused on now.">
	<section class="py-12">
		<p class="mb-4 font-mono text-xs font-bold tracking-[0.14em] text-yellow-300 uppercase">Now</p>
		<h1 class="m-0 max-w-[16ch] text-[clamp(2.75rem,7vw,5.75rem)] leading-[1.02] font-bold tracking-[-0.055em]">Now</h1>
		<p class="mt-6 max-w-2xl text-[clamp(1.15rem,3vw,1.45rem)] text-zinc-400">What I am focused on at the moment.</p>
	</section>

	<section class="[&_ul]:list-disc [&_ul]:pl-6">
		<ul>
			<li>Current work focus.</li>
			<li>Things I am learning.</li>
			<li>Projects I am exploring.</li>
		</ul>
	</section>
</BaseLayout>
