---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} wide>
	<section class="hero">
		<p class="eyebrow">verycoolperson.com</p>
		<h1>Writing, work, and notes from a very cool person.</h1>
		<p class="lede">
			This is a personal site for essays, projects, professional notes, and whatever else is worth
			putting somewhere I control.
		</p>
		<div class="actions">
			<a class="button" href="/blog">Read the blog</a>
			<a class="button secondary" href="/work">See the work</a>
		</div>
	</section>

	<section class="grid two-up">
		<div class="card">
			<h2>Latest writing</h2>
			{
				posts.length > 0 ? (
					<ul class="post-list compact">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<span><FormattedDate date={post.data.pubDate} /></span>
							</li>
						))}
					</ul>
				) : (
					<p>No posts yet.</p>
				)
			}
		</div>
		<div class="card">
			<h2>Selected work</h2>
			<p>
				A place to highlight projects, talks, writing, open source, case studies, or anything else
				that helps tell the story of your work.
			</p>
			<p><a href="/work">Go to work →</a></p>
		</div>
	</section>
</BaseLayout>
